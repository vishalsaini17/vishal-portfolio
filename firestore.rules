rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Security Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() 
        && request.auth.token.email == 'vishalsaini154@gmail.com';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    // --- Entity Validation Blueprints ---
    function isValidContact(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'message', 'createdAt'])
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 256
        && data.email is string && data.email.size() >= 5 && data.email.size() <= 256
        && data.message is string && data.message.size() >= 5 && data.message.size() <= 5000
        && data.createdAt is timestamp && data.createdAt == request.time;
    }

    function isValidResume(data) {
      return data.keys().hasAll(['id', 'fileName', 'content', 'updatedAt'])
        && data.id == 'latest'
        && data.fileName is string && data.fileName.size() > 0 && data.fileName.size() <= 128
        && data.content is string && data.content.size() > 0 && data.content.size() <= 1048000
        && data.updatedAt is timestamp && data.updatedAt == request.time;
    }

    // --- Collection Routes & Access Policies ---

    match /contacts/{contactId} {
      allow create: if isValidId(contactId)
        && isValidContact(incoming())
        && incoming().id == contactId;

      allow read, delete: if isAdmin();
    }

    match /resumes/{resumeId} {
      allow read: if true;

      allow create, update: if isAdmin()
        && isValidId(resumeId)
        && isValidResume(incoming())
        && incoming().id == resumeId;

      allow delete: if isAdmin() && isValidId(resumeId);
    }

    match /profile/{profileId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Blogs Validation ---
    function isValidBlogPost(data) {
      return data.keys().hasAll(['id', 'title', 'excerpt', 'content', 'status', 'createdAt', 'updatedAt'])
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 512
        && data.excerpt is string && data.excerpt.size() <= 1000
        && data.content is string && data.content.size() <= 1048000
        && (data.status == 'published' || data.status == 'draft')
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /blogs/{blogId} {
      allow read: if isAdmin();
      allow read: if resource.data.status == 'published';
      allow create, update: if isAdmin()
        && isValidId(blogId)
        && isValidBlogPost(incoming())
        && incoming().id == blogId;
      allow delete: if isAdmin() && isValidId(blogId);
    }
  }
}
